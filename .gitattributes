# Normalize line endings on checkout
* text=auto

# Shell scripts always LF
*.sh text eol=lf

# PowerShell scripts always CRLF
*.ps1 text eol=crlf

# Python files LF
*.py text eol=lf

# Configs LF
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf
*.md   text eol=lf
*.env* text eol=lf

# Binaries — no line ending conversion
*.png  binary
*.jpg  binary
*.ico  binary
